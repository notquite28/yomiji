{
  "expo": {
    "name": "読路 (Yomiji)",
    "slug": "yomiji",
    "scheme": "yomiji",
    "version": "0.3.3",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "icon": "./assets/yomiji.png",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "app.yomiji",
      "buildNumber": "6"
    },
    "android": {
      "package": "app.yomiji",
      "versionCode": 6,
      "adaptiveIcon": {
        "foregroundImage": "./assets/yomiji.png",
        "backgroundColor": "#f7f4ef"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED",
        "expo-notifications"
      ]
    },
    "plugins": [
      "expo-secure-store",
      "expo-sqlite",
      "expo-notifications"
    ],
    "extra": {
      "eas": {
        "projectId": "1027f19d-260b-4b0e-8d14-88a52844763a"
      }
    },
    "owner": "notquite"
  }
}
